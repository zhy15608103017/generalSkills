{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI 代码审查结果",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "blocking_findings",
    "warnings",
    "verification_notes",
    "confidence"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "needs_human"]
    },
    "verdict_label": {
      "type": "string",
      "description": "由本地运行器在最终输出中补充的中文展示标签。"
    },
    "summary": {
      "type": "string"
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "verification_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewer_failures": {
      "type": "array",
      "description": "由本地审查脚本补充的模型调用失败信息，不由审查模型直接生成。",
      "items": {
        "$ref": "#/$defs/reviewer_failure"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "title",
        "file",
        "line",
        "evidence",
        "impact",
        "suggested_fix"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "title": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "evidence": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "suggested_fix": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "description": "由本地运行器在最终输出中补充的审查来源信息。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["reviewer", "provider", "model"],
            "properties": {
              "reviewer": {
                "type": "string",
                "enum": ["primary", "second", "requirement-auditor", "unknown"]
              },
              "provider": {
                "type": "string"
              },
              "model": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "reviewer_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "reviewer",
        "provider",
        "model",
        "category",
        "retryable",
        "message",
        "status",
        "attempts"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["preflight", "requirement_audit", "code_review", "unknown"]
        },
        "reviewer": {
          "type": "string",
          "enum": ["primary", "second", "requirement-auditor", "unknown"]
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["timeout", "network", "auth", "rate_limit", "server", "config", "bad_response", "cli", "unknown"]
        },
        "retryable": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        },
        "status": {
          "type": ["integer", "null"]
        },
        "attempts": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    }
  }
}



#主审模型配置(必须配置)尽量选用推理能力强的模型，建议deepSeek-v4-pro以上等级模型
AI_REVIEW_PRIMARY_PROVIDER=openai-compatible
AI_REVIEW_PRIMARY_MODEL=<primary-model-id> #模型名
AI_REVIEW_PRIMARY_BASE_URL=<primary-base-url> #地址
AI_REVIEW_PRIMARY_API_KEY=<primary-api-key> #key
AI_REVIEW_TRANSPORT=openai-compatible #调用方式
AI_REVIEW_API_STYLE=chat #API 风格

#次审模型配置可选，建议使用和主模型不同系列的模型，只有一种系列模型可以选用比主模型稍次等级模型
AI_REVIEW_SECOND_PROVIDER=openai-compatible
AI_REVIEW_SECOND_MODEL=<second-model-id>
AI_REVIEW_SECOND_BASE_URL=<second-base-url>
AI_REVIEW_SECOND_API_KEY=<second-api-key>
AI_REVIEW_SECOND_TRANSPORT=openai-compatible
AI_REVIEW_SECOND_API_STYLE=chat

#双模型启用配置默认为auto,开启后会并行处理，可选择always（强制开启双模型），off（关闭）， auto（自动）  默认为auto，达到阈值自动开启双模型审核，对审核要求较高使用always
AI_REVIEW_SECOND_REVIEW_MODE=auto



#更多配置参数查看https://github.com/zhy15608103017/generalSkills/blob/main/docs/code-review-loop.md

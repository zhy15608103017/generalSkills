# 主审模型配置（必须配置）
# AI_REVIEW_PRIMARY_PROVIDER=openai-compatible
# AI_REVIEW_PRIMARY_MODEL=<primary-model-id>
# AI_REVIEW_PRIMARY_BASE_URL=<primary-base-url>
# AI_REVIEW_PRIMARY_API_KEY=<primary-api-key>
# AI_REVIEW_TRANSPORT=openai-compatible
# AI_REVIEW_API_STYLE=chat
# AI_REVIEW_STRICT_OUTPUT=true

# 二审模型配置（可选）
# AI_REVIEW_SECOND_PROVIDER=openai-compatible
# AI_REVIEW_SECOND_MODEL=<second-model-id>
# AI_REVIEW_SECOND_BASE_URL=<second-base-url>
# AI_REVIEW_SECOND_API_KEY=<second-api-key>
# AI_REVIEW_SECOND_TRANSPORT=openai-compatible
# AI_REVIEW_SECOND_API_STYLE=chat

# 二审策略：always 并行运行双审；auto 达到阈值后再运行二审；off 关闭二审。
# AI_REVIEW_SECOND_REVIEW_MODE=auto

# 更多配置请查看已安装 skill 的 references/configuration.md。
